# Конфигурация для прохождения CI
skip_list:
  - var-naming          # Разрешаем глобальную infra_state
  - metadata            # Пропускаем сложные проверки метаданных роли
  - role-name[path]     # Разрешает импорты по путям в тестах
  - risky-shell-pipe    # Пропускаем, если пайпы уже настроены через pipefail
  - no-changed-when     # Разрешаем командам регистрации менять состояние
  - yaml[comments]      # Игнорировать пробелы в комментариях (на всякий случай)

exclude_paths:
  - roles/windows_common/
  - playbooks/windows.yml
  - playbooks/windows_selective.yml
  - site.yaml           # Исключаем главный файл, так как он импортирует Windows-плейбук
