# Полная конфигурация качества (Production Profile)
skip_list:
  - var-naming          # Оставляем глобальную infra_state (архитектурное решение)
  - role-name[path]     # Разрешаем импорты по путям в тестах
  - risky-shell-pipe    # Пропускаем, так как pipefail настроен вручную
  - no-changed-when     # Разрешаем командам регистрации менять состояние
