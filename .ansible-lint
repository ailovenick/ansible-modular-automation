# Настройки линтера для соблюдения баланса между качеством и гибкостью
skip_list:
  - var-naming          # Разрешаем глобальные переменные (как infra_state)
  - meta-incorrect      # Не ругаться на дефолтные поля в meta (author/company)
  - yaml[comments]      # Игнорировать отсутствие пробела в начале комментариев
  - name[play]          # Разрешаем не называть каждый play (например, в тестах)
  - role-name[path]     # Разрешаем пути в импортах для тестов
  - syntax-check        # Пропускаем, так как коллекции Windows недоступны в CI
